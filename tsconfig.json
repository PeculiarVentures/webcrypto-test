{
  "compilerOptions": {
    "target": "es2015",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./build",
    "removeComments": true,
    "importHelpers": true,
    "types": [
      "node"
    ],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "exclude": [
    "test",
    "build"
  ]
}